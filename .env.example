# Server configuration
PORT=8080
NODE_ENV=development

# Database path (default: ./data/airdrop-intel.db)
# DB_PATH=./data/airdrop-intel.db

# ---- Required ----
# Get free API key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your-etherscan-api-key

# ---- Optional ----
# Get free key at https://rapidapi.com (one key works for all RapidAPI services)
RAPIDAPI_KEY=your-rapidapi-key

# Twitter/X search via RapidAPI wrapper (uses same RAPIDAPI_KEY above)
# Recommended: https://rapidapi.com/Glavier/api/twitter135 → subscribe to Basic (free, 100 req/mo)
# Free tier + 2h cache = ~200 unique searches/mo — fine for MVP
TWITTER_RAPIDAPI_HOST=twitter135.p.rapidapi.com

# Get from @BotFather in Telegram — required for Telegram bot notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
